{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "hono serve --use 'logger()' src/index.ts",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "hono": "hono",
    "format": "bun x oxfmt .",
    "lint": "bun x oxlint --fix .",
    "check": "bun x tsc check --write ."
  },
  "dependencies": {
    "hono": "4.12.5",
    "ts-ics": "2.4.3"
  },
  "devDependencies": {
    "wrangler": "4.71.0"
  }
}
